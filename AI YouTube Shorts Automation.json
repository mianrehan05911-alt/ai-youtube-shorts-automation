    {
      "parameters": {
        "jsCode": "// Parse the SEO metadata JSON from the AI output\nconst rawOutput = $input.first().json.output;\n\n// Clean the output - remove markdown code blocks if present\nlet cleaned = rawOutput.replace(/```json/g, '').replace(/```/g, '').trim();\n\n// Find JSON object in the string\nconst jsonMatch = cleaned.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) {\n  throw new Error('No JSON found in AI output: ' + rawOutput);\n}\n\nconst metadata = JSON.parse(jsonMatch[0]);\n\n// Also get data from previous nodes stored in workflow\n// We need to pass data forward\nreturn [\n  {\n    json: {\n      title: metadata.title,\n      description: metadata.description,\n      tags: metadata.tags,\n      search_keyword: metadata.search_keyword,\n      // These will be filled by previous nodes via expressions\n      topic: '',\n      script: ''\n    }\n  }\n];"
      },
