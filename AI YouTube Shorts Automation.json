    {
      "parameters": {
        "jsCode": "// Extract video download URL from Pexels response\nconst pexelsData = $input.first().json;\n\nif (!pexelsData.videos || pexelsData.videos.length === 0) {\n  throw new Error('No videos found on Pexels for this keyword');\n}\n\nconst video = pexelsData.videos[0];\n\n// Get the HD video file\nconst videoFiles = video.video_files;\nlet selectedFile = videoFiles.find(f => f.quality === 'hd') || \n                   videoFiles.find(f => f.quality === 'sd') || \n                   videoFiles[0];\n\nreturn [\n  {\n    json: {\n      video_url: selectedFile.link,\n      video_id: video.id,\n      video_width: selectedFile.width,\n      video_height: selectedFile.height,\n      pexels_url: video.url\n    }\n  }\n];"
      },
